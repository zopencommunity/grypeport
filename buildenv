zopen_init() {
  # Enable CGO without explicit CC/CXX - let Go use its defaults
  export CGO_ENABLED=1
  # Use absolute path for GOTMPDIR to avoid issues when changing directories
  export GOTMPDIR=$(pwd)/gotmp
  mkdir -p $GOTMPDIR
  # Ensure GOROOT/bin is first in PATH to avoid version mismatch
  export PATH=$GOROOT/bin:$PATH
  # Use patched Go toolchain (grafana-style workaround for z/OS CGO linking)
  export PATH=$PATH:$GOROOT/go-build-zos/bin
}

zopen_config() {
  # Ensure CGO is enabled for config processing (let Go detect compiler)
  export CGO_ENABLED=1
  
  # We're already in grypeport directory, no need to cd ..
  rm -rf go.work

  # Pre-build go-sqlite3 as shared library (Grafana approach)
  rm -rf go-sqlite3
  git clone https://github.com/mattn/go-sqlite3.git
  cd go-sqlite3
  # Build the DLL for go-sqlite3
  clang -shared -fvisibility=default -o sqlite3-binding.so sqlite3-binding.c \
    -DPATH_MAX=1023 \
    -D_AE_BIMODAL=1 \
    -D_ALL_SOURCE \
    -U_ENHANCED_ASCII_EXT \
    -D_ENHANCED_ASCII_EXT=0xFFFFFFFF \
    -D_Export=extern \
    -D_LARGE_TIME_API \
    -D_OPEN_MSGQ_EXT \
    -D_OPEN_SYS_FILE_EXT=1 \
    -D_OPEN_SYS_SOCK_IPV6 \
    -D_UNIX03_SOURCE \
    -D_UNIX03_THREADS \
    -D_UNIX03_WITHDRAWN \
    -D_XOPEN_SOURCE=600 \
    -D_XOPEN_SOURCE_EXTENDED \
    -D_XPLATFORM_SOURCE=1 \
    -D__static_assert=static_assert \
    -D_POSIX_C_SOURCE=200809L \
    -fasm \
    -fzos-le-char-mode=ascii \
    -isystem/usr/include \
    -m64
  chtag -tc1047 sqlite3-binding.x
  mv ./sqlite3-binding.c ./sqlite3-binding.c.ignore
  
  # Patch sqlite3.go to use the pre-built side deck (Grafana approach)
  GO_SQLITE3_DIR=$(pwd)
  # Insert z/OS CGO directives after the openbsd LDFLAGS line
  # Use the side deck file directly - Go will handle the linking
  sed -i '/^#cgo openbsd LDFLAGS:/a\
#cgo zos LDFLAGS: ZOPEN-REPLACE-DIR/sqlite3-binding.x' sqlite3.go
  sed -i "s#ZOPEN-REPLACE-DIR#${GO_SQLITE3_DIR}#g" sqlite3.go
  cd ..

  # Clone and patch mmap-go
  rm -rf mmap-go
  git clone https://github.com/edsrzf/mmap-go.git
  cd mmap-go
  # Patch mmap_unix.go to add zos build tag
  sed -i 's/+build darwin dragonfly freebsd linux openbsd solaris netbsd aix/+build darwin dragonfly freebsd linux openbsd solaris netbsd aix zos/' mmap_unix.go
  cd ..

  # Clone and create z/OS-specific files for xdg
  rm -rf xdg
  git clone https://github.com/adrg/xdg.git
  cd xdg
  # Create pathutil_zos.go
  cat > internal/pathutil/pathutil_zos.go << 'XDGEOF1'
//go:build zos
// +build zos

package pathutil

import (
	"errors"
	"io/fs"
	"os"
	"path/filepath"
	"strings"
)

func UserHomeDir() string {
	if home := os.Getenv("HOME"); home != "" {
		return home
	}
	return "/"
}

func Exists(path string) bool {
	_, err := os.Stat(path)
	return err == nil || errors.Is(err, fs.ErrExist)
}

func ExpandHome(path string) string {
	home := UserHomeDir()
	if path == "" || home == "" {
		return path
	}
	if path[0] == '~' {
		return filepath.Join(home, path[1:])
	}
	if strings.HasPrefix(path, "$HOME") {
		return filepath.Join(home, path[5:])
	}
	return path
}
