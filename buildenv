GRYPE_VERSION="0.80.0"

###
### Build control file for the grype port
###

###
### Required Environment Variables
###
export ZOPEN_PROJECT_NAME="grype"
export ZOPEN_BUILD_LINE="STABLE"
export ZOPEN_STABLE_URL="https://github.com/anchore/grype.git"
export ZOPEN_STABLE_TAG="v0.80.0"
export ZOPEN_STABLE_DEPS="make coreutils wharf check_go check_clang sqlite"
export ZOPEN_DEV_URL=""
export ZOPEN_DEV_DEPS="check_go"
export ZOPEN_CATEGORIES="security devops"
export ZOPEN_RUNTIME_DEPS=""
# export ZOPEN_SYSTEM_PREREQ="zos25" # optional system pre-req (default=zos25)


###
### Build settings (Port type: BUILD, Build system: Go)
###
### Settings for Go build system
export ZOPEN_COMP=GO
export ZOPEN_CONFIGURE="zopen_wharf"
export ZOPEN_CONFIGURE_MINIMAL=1
export ZOPEN_MAKE="zopen_build"
export ZOPEN_MAKE_MINIMAL=1
export ZOPEN_CHECK="skip"
export ZOPEN_INSTALL="zopen_install"
export ZOPEN_CLEAN="zopen_clean"


