zopen_install() {
  # Create install directories
  mkdir -p "${ZOPEN_INSTALL_DIR}/lib"
  mkdir -p "${ZOPEN_INSTALL_DIR}/bin"
  
  # Copy pre-built sqlite3 shared library
  mv ../go-sqlite3/sqlite3-binding.so "${ZOPEN_INSTALL_DIR}/lib/sqlite3-binding.so"
  
  # Build grype binary with limited parallelism to avoid OOM on z/OS
  # CGO builds require more memory, so we limit parallel compilation
  export GOMAXPROCS=1
  export CGO_ENABLED=1
  # We're already in grype directory from zopen_wharf
  echo "Building with CGO_ENABLED=$CGO_ENABLED in $(pwd)"
  go build -v -p 1 -o grype-bin ./cmd/grype
  
  # Verify the binary was built with CGO
  if [ -f grype-bin ]; then
    echo "Binary built successfully"
    ./grype-bin version | grep -i "go-sqlite3" || echo "Warning: Binary may not have CGO support"
  else
    echo "ERROR: grype-bin not found after build"
    return 1
  fi
  
  # Copy the built binary to the install directory
  cp grype-bin "${ZOPEN_INSTALL_DIR}/bin/grype"
}

zopen_clean() {
  # Clean up cloned dependencies and build artifacts
  cd ..
  rm -rf .wharf_cache wharf_port
  rm -rf mmap-go xdg continuity go-mtree termenv containerd
  cd grype
  # Remove replace directives from go.mod
  go mod edit -dropreplace github.com/edsrzf/mmap-go
  go mod edit -dropreplace github.com/adrg/xdg
  go mod edit -dropreplace github.com/containerd/continuity
  go mod edit -dropreplace github.com/vbatts/go-mtree
  go mod edit -dropreplace github.com/muesli/termenv
  go mod edit -dropreplace github.com/containerd/containerd
  go mod edit -dropreplace github.com/go-git/go-git/v5
  cd ..
}

