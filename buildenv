###
### Custom Build Logic (if applicable)
###
zopen_init() {
  # Set up clang for CGO compilation
  export CC=clang
  export CXX=clang++
  export CGO_ENABLED=1  # Enable CGO for SQLite support
}

zopen_wharf() {
  cd ..
  rm -rf go.work

  # Clone and patch mmap-go
  rm -rf mmap-go
  git clone https://github.com/edsrzf/mmap-go.git
  cd mmap-go
  git apply ../patches/mmap-go.gopatch
  cd ..

  # Clone and patch xdg
  rm -rf xdg
  git clone https://github.com/adrg/xdg.git
  cd xdg
  git apply ../patches/xdg.gopatch
  cd ..

  # Clone and patch continuity
  rm -rf continuity
  git clone https://github.com/containerd/continuity.git
  cd continuity
  git apply ../patches/continuity.gopatch
  cd ..

  # Clone and patch go-mtree
  rm -rf go-mtree
  git clone https://github.com/vbatts/go-mtree.git
  cd go-mtree
  git apply ../patches/go-mtree.gopatch
  cd ..

  # Clone and patch termenv
  rm -rf termenv
  git clone https://github.com/muesli/termenv.git
  cd termenv
  git apply ../patches/termenv.gopatch
  cd ..

  # Clone and patch containerd
  rm -rf containerd
  git clone https://github.com/containerd/containerd.git
  cd containerd
  git apply ../patches/containerd.gopatch
  cd ..

  # Initialize Go workspace with all modules
  go work init ./mmap-go ./xdg ./continuity ./go-mtree ./termenv ./containerd ./grype
  
  # Run wharf to process dependencies for z/OS
  wharf ./grype/...
  
  cd ./grype
  go mod tidy
}

zopen_build() {
  # Build grype binary with limited parallelism to avoid OOM on z/OS
  # CGO builds require more memory, so we limit parallel compilation
  export GOMAXPROCS=1
  go build -p 1 -o grype ./cmd/grype
}

zopen_install() {
  # Copy the built binary to the install directory
  mkdir -p "${ZOPEN_INSTALL_DIR}/bin"
  cp grype "${ZOPEN_INSTALL_DIR}/bin/"
}

zopen_clean() {
  # Clean up Go workspace artifacts and cloned dependencies
  cd ..
  rm -rf go.work go.work.sum .wharf_cache wharf_port
  rm -rf mmap-go xdg continuity go-mtree termenv
  cd grype
}

